# Copy this file to .env and fill in the values for your environment.

# API base URL — set to /api in dev (Vite proxies it) or the full backend URL in production.
VITE_API_URL=/api

# Backend the Vite dev server proxies /api to (dev only).
# Use http://localhost:8000 for local backend, or the Railway preprod URL to test against it.
VITE_DEV_PROXY_TARGET=http://localhost:8000
# VITE_DEV_PROXY_TARGET=https://munlightapi-preprod.up.railway.app
